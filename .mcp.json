{
  "mcpServers": {
    "gopls-mcp": {
      "_comment": "Detached mode/SSE not mature, so don't use daemon mode",
      "command": "gopls",
      "args": [
        "mcp"
      ]
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": [
        "serve",
        "--mcp"
      ]
    }
  }
}
